{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "XGTools",
  "version": "0.1.1",
  "identifier": "com.tauri-app.xgtools",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "XGTools",
        "width": 1000,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 800,
        "decorations": false,
        "shadow": true
      },
      {
        "label": "key_visualizer",
        "title": "key_visualizer",
        "url": "index.html",
        "width": 270,
        "height": 300,
        "decorations": false,
        "shadow": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false
      },
      {
        "label": "dock",
        "url": "index.html",
        "maximizable": true,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false
      },
      {
        "label": "screenshot",
        "title": "XGTools Screenshot Overlay",
        "url": "index.html",
        "decorations": false,
        "shadow": false,
        "transparent": true,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "resizable": false,
        "width": 1,
        "height": 1,
        "visible": false,
        "focus": false,
        "backgroundThrottling": "disabled"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/ocr/*": "resources/ocr/",
      "resources/ffmpeg/*": "resources/ffmpeg/"
    }
  }
}